// =============================================================
// FórumNL — Schema Prisma
// Diseño según ESPECIFICACION_PORTAL_VOTACION_VECINAL.md §5
// Principio crítico: tabla `voto` NO tiene FK a `usuario` para
// preservar secrecía. Solo se conecta vía `folioAnonimo`.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ROLES Y ESTATUS -----------------------------------------

enum Rol {
  ADMIN
  COMITE
  USUARIO
}

enum EstatusUsuario {
  PENDIENTE
  VERIFICADO
  RECHAZADO
  SUSPENDIDO
}

enum EstatusAsamblea {
  BORRADOR
  PUBLICADA
  PADRON_ABIERTO
  PADRON_CERRADO
  EN_JORNADA
  CERRADA
  CON_ACTA
}

enum TipoProceso {
  ELECCION_PLANILLA
  PRIORIZACION_PUNTAJE
  SI_NO
  APROBACION_MULTIPLE
  ASAMBLEA_DELIBERATIVA
}

enum EstatusProceso {
  CONFIGURANDO
  ABIERTO
  CERRADO
  COMPUTADO
  CON_ACTA
}

enum CategoriaReporte {
  SEGURIDAD
  AGUA_DRENAJE
  PARQUES
  BANQUETAS
  ALUMBRADO
  BASURA
  OTROS
}

enum EstatusReporte {
  ABIERTO
  EN_PROCESO
  CONVERTIDO_A_VOTACION
  RESUELTO
  CERRADO
}

// --- ENTIDADES BASE ------------------------------------------

model Fraccionamiento {
  id              String   @id @default(uuid())
  nombre          String
  municipio       String   @default("Monterrey")
  estado          String   @default("Nuevo León")
  totalViviendas  Int      @default(0)
  avisoPrivacidad String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  viviendas Vivienda[]
  asambleas Asamblea[]
  reportes  Reporte[]
  posts     Post[]
}

model Vivienda {
  id                 String          @id @default(uuid())
  fraccionamientoId  String
  identificador      String
  estatus            String          @default("activa")
  fraccionamiento    Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  usuario            Usuario?

  @@unique([fraccionamientoId, identificador])
}

model Usuario {
  id                String         @id @default(uuid())
  // Identidad y contacto
  telefono          String         @unique     // +52 8132558755
  nombreCompleto    String         @default("")
  curp              String?        @unique
  fechaNacimiento   DateTime?
  sexo              String?        // "Hombre" | "Mujer"
  domicilio         String?
  // Vivienda asignada (one-to-one)
  viviendaId        String?        @unique
  vivienda          Vivienda?      @relation(fields: [viviendaId], references: [id])
  // Biométrico (se guarda en Supabase Storage)
  ineFrontePath     String?
  selfiePath        String?
  embeddingFacial   Bytes?         // 128 floats en bytes
  // Auth
  rol               Rol            @default(USUARIO)
  estatus           EstatusUsuario @default(PENDIENTE)
  fechaVerificacion DateTime?
  // Auditoría
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ultimoAcceso      DateTime?

  // Relaciones
  codigosVerificacion CodigoVerificacion[]
  posts               Post[]
  comentarios         Comentario[]
  likes               Like[]
  reportes            Reporte[]
  asambleasOrganiza   MesaOrganizadora[]
  asistenciasAsamblea AsistenteAsamblea[]
  mensajesAsamblea    MensajeAsamblea[]
}

model CodigoVerificacion {
  id        String   @id @default(uuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  telefono  String
  codigo    String   // 6 dígitos
  proposito String   @default("login") // "login" | "registro"
  usado     Boolean  @default(false)
  expiraEn  DateTime
  createdAt DateTime @default(now())

  @@index([telefono, codigo])
}

// --- ASAMBLEAS Y PROCESOS DE VOTACIÓN ------------------------

model Asamblea {
  id                 String          @id @default(uuid())
  fraccionamientoId  String
  fraccionamiento    Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  titulo             String
  descripcion        String          @default("")
  fechaPublicacion   DateTime        @default(now())
  fechaCierrePadron  DateTime
  jornadaInicio      DateTime
  jornadaFin         DateTime
  lugarPresencial    String?
  reglas             String          @default("")
  estatus            EstatusAsamblea @default(BORRADOR)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  procesos           Proceso[]
  mesa               MesaOrganizadora[]
  padron             PadronAsamblea[]
  incidencias        Incidencia[]
  seguimiento        Seguimiento[]
  asistentes         AsistenteAsamblea[]
  mensajes           MensajeAsamblea[]
}

model MesaOrganizadora {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  rolMesa    String   @default("integrante") // "responsable" | "integrante" | "moderador"

  @@unique([asambleaId, usuarioId])
}

// Snapshot de viviendas elegibles al cerrar padrón.
// Cada entrada incluye un folio anónimo de 1 uso para votar.
model PadronAsamblea {
  id                  String   @id @default(uuid())
  asambleaId          String
  asamblea            Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  viviendaId          String
  usuarioId           String
  folioAnonimo        String   // generado random al cerrar padrón
  elegible            Boolean  @default(true)
  motivoInelegibilidad String?

  @@unique([asambleaId, viviendaId])
  @@unique([asambleaId, folioAnonimo])
  @@index([folioAnonimo])
}

model Proceso {
  id           String         @id @default(uuid())
  asambleaId   String
  asamblea     Asamblea       @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  tipo         TipoProceso
  titulo       String
  descripcion  String         @default("")
  orden        Int            @default(0)
  estatus      EstatusProceso @default(CONFIGURANDO)
  createdAt    DateTime       @default(now())

  opciones Opcion[]
  votos    Voto[]
  emisiones EmisionPadron[]
  acta     Acta?
}

model Opcion {
  id          String  @id @default(uuid())
  procesoId   String
  proceso     Proceso @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String  @default("")
  // "Infórmate": contenido editable por el comité
  infoMd      String  @default("")
  imagenPath  String?
  orden       Int     @default(0)

  integrantes PlanillaIntegrante[]
}

// Integrantes (sólo aplica a planilla)
model PlanillaIntegrante {
  id       String @id @default(uuid())
  opcionId String
  opcion   Opcion @relation(fields: [opcionId], references: [id], onDelete: Cascade)
  puesto   String
  nombre   String
}

// VOTOS — sin FK a usuario por secrecía
model Voto {
  id            String   @id @default(uuid())
  procesoId     String
  proceso       Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  folioAnonimo  String
  contenido     Json
  canal         String   @default("digital") // "digital" | "presencial"
  emitidoAt     DateTime @default(now())

  @@unique([procesoId, folioAnonimo])
  @@index([procesoId])
}

// Marca de quién ya votó (tabla separada de voto para preservar secrecía)
model EmisionPadron {
  id            String   @id @default(uuid())
  procesoId     String
  proceso       Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  folioAnonimo  String
  canal         String   @default("digital")
  marcadoAt     DateTime @default(now())

  @@unique([procesoId, folioAnonimo])
}

model Incidencia {
  id           String   @id @default(uuid())
  asambleaId   String
  asamblea     Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  tipo         String   // "duplicidad" | "identidad_fallida" | etc
  descripcion  String
  reportadoAt  DateTime @default(now())
}

model Acta {
  id          String   @id @default(uuid())
  procesoId   String   @unique
  proceso     Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  pdfPath     String   // ruta en Supabase Storage
  hashSha256  String
  resultados  Json
  generadaAt  DateTime @default(now())
}

model Seguimiento {
  id                 String   @id @default(uuid())
  asambleaId         String
  asamblea           Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  prioridad          Int
  titulo             String
  responsable        String   @default("")
  accion             String   @default("")
  fechaCompromiso    DateTime?
  evidenciaEsperada  String   @default("")
  estatus            String   @default("pendiente")
  actualizadoAt      DateTime @updatedAt
}

// --- ASAMBLEA DELIBERATIVA (chat/foro) -----------------------

model AsistenteAsamblea {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  unidoAt    DateTime @default(now())

  @@unique([asambleaId, usuarioId])
}

model MensajeAsamblea {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  contenido  String
  createdAt  DateTime @default(now())

  @@index([asambleaId, createdAt])
}

// --- FEED DE COMUNIDAD ---------------------------------------

model Post {
  id                String          @id @default(uuid())
  fraccionamientoId String
  fraccionamiento   Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  autorId           String?
  autor             Usuario?        @relation(fields: [autorId], references: [id])
  // Si autor es null => post automático del sistema
  tipo              String          @default("manual") // "manual" | "auto_evento" | "auto_resultado" | "auto_seguimiento"
  titulo            String          @default("")
  contenido         String
  imagenPath        String?
  // Si está vinculado a una asamblea/proceso/reporte:
  asambleaId        String?
  procesoId         String?
  reporteId         String?
  createdAt         DateTime        @default(now())

  comentarios Comentario[]
  likes       Like[]

  @@index([fraccionamientoId, createdAt])
}

model Comentario {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  contenido String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Like {
  id        String  @id @default(uuid())
  postId    String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([postId, usuarioId])
}

// --- REPORTES CIUDADANOS -------------------------------------

model Reporte {
  id                 String           @id @default(uuid())
  fraccionamientoId  String
  fraccionamiento    Fraccionamiento  @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  autorId            String
  autor              Usuario          @relation(fields: [autorId], references: [id])
  categoria          CategoriaReporte
  titulo             String
  descripcion        String
  imagenPath         String?
  ubicacionLat       Float?
  ubicacionLng       Float?
  estatus            EstatusReporte   @default(ABIERTO)
  convertidoEnProceso String?         // ID del proceso si se convirtió en votación
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([fraccionamientoId, createdAt])
}
