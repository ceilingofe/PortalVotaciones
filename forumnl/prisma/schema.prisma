// =============================================================
// FórumNL — Schema Prisma (actualizado con trazabilidad)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

enum Rol {
  ADMIN
  COMITE
  USUARIO
}
enum EstatusUsuario {
  PENDIENTE
  VERIFICADO
  RECHAZADO
  SUSPENDIDO
}
enum EstatusAsamblea {
  BORRADOR
  PUBLICADA
  PADRON_ABIERTO
  PADRON_CERRADO
  EN_JORNADA
  CERRADA
  CON_ACTA
}
enum TipoProceso {
  ELECCION_PLANILLA
  PRIORIZACION_PUNTAJE
  SI_NO
  APROBACION_MULTIPLE
  ASAMBLEA_DELIBERATIVA
}
enum EstatusProceso {
  CONFIGURANDO
  ABIERTO
  CERRADO
  COMPUTADO
  CON_ACTA
}
enum CategoriaReporte {
  SEGURIDAD
  AGUA_DRENAJE
  PARQUES
  BANQUETAS
  ALUMBRADO
  BASURA
  OTROS
}
enum EstatusReporte {
  ABIERTO
  EN_PROCESO
  CONVERTIDO_A_VOTACION
  RESUELTO
  CERRADO
}

// ─── ENTIDADES BASE ───────────────────────────────────────────

model Fraccionamiento {
  id             String   @id @default(uuid())
  nombre         String
  municipio      String   @default("Monterrey")
  estado         String   @default("Nuevo León")
  totalViviendas Int      @default(0)
  avisoPrivacidad String  @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  viviendas Vivienda[]
  asambleas Asamblea[]
  reportes  Reporte[]
  posts     Post[]
}

model Vivienda {
  id                String          @id @default(uuid())
  fraccionamientoId String
  identificador     String
  estatus           String          @default("activa")
  fraccionamiento   Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  usuario           Usuario?

  @@unique([fraccionamientoId, identificador])
}

model Usuario {
  id                String         @id @default(uuid())
  telefono          String         @unique
  nombreCompleto    String         @default("")
  curp              String?        @unique
  fechaNacimiento   DateTime?
  sexo              String?
  domicilio         String?
  viviendaId        String?        @unique
  vivienda          Vivienda?      @relation(fields: [viviendaId], references: [id])
  ineFrontePath     String?
  selfiePath        String?
  embeddingFacial   Bytes?
  rol               Rol            @default(USUARIO)
  estatus           EstatusUsuario @default(PENDIENTE)
  fechaVerificacion DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ultimoAcceso      DateTime?

  codigosVerificacion     CodigoVerificacion[]
  posts                   Post[]
  comentarios             Comentario[]
  likes                   Like[]
  reportes                Reporte[]
  asambleasOrganiza       MesaOrganizadora[]
  asistenciasAsamblea     AsistenteAsamblea[]
  mensajesAsamblea        MensajeAsamblea[]
  actualizacionesSeg      ActualizacionSeguimiento[]
}

model CodigoVerificacion {
  id        String   @id @default(uuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  telefono  String
  codigo    String
  proposito String   @default("login")
  usado     Boolean  @default(false)
  expiraEn  DateTime
  createdAt DateTime @default(now())

  @@index([telefono, codigo])
}

// ─── ASAMBLEAS ────────────────────────────────────────────────

model Asamblea {
  id                String          @id @default(uuid())
  fraccionamientoId String
  fraccionamiento   Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  titulo            String
  descripcion       String          @default("")
  fechaPublicacion  DateTime        @default(now())
  fechaCierrePadron DateTime
  jornadaInicio     DateTime
  jornadaFin        DateTime
  lugarPresencial   String?
  reglas            String          @default("")
  estatus           EstatusAsamblea @default(BORRADOR)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  procesos    Proceso[]
  mesa        MesaOrganizadora[]
  padron      PadronAsamblea[]
  incidencias Incidencia[]
  seguimiento Seguimiento[]
  asistentes  AsistenteAsamblea[]
  mensajes    MensajeAsamblea[]
}

model MesaOrganizadora {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  rolMesa    String   @default("integrante")

  @@unique([asambleaId, usuarioId])
}

model PadronAsamblea {
  id                   String   @id @default(uuid())
  asambleaId           String
  asamblea             Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  viviendaId           String
  usuarioId            String
  folioAnonimo         String
  elegible             Boolean  @default(true)
  motivoInelegibilidad String?

  @@unique([asambleaId, viviendaId])
  @@unique([asambleaId, folioAnonimo])
  @@index([folioAnonimo])
}

model Proceso {
  id          String         @id @default(uuid())
  asambleaId  String
  asamblea    Asamblea       @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  tipo        TipoProceso
  titulo      String
  descripcion String         @default("")
  orden       Int            @default(0)
  estatus     EstatusProceso @default(CONFIGURANDO)
  createdAt   DateTime       @default(now())

  opciones  Opcion[]
  votos     Voto[]
  emisiones EmisionPadron[]
  acta      Acta?
}

model Opcion {
  id          String  @id @default(uuid())
  procesoId   String
  proceso     Proceso @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String  @default("")
  infoMd      String  @default("")
  imagenPath  String?
  orden       Int     @default(0)

  integrantes PlanillaIntegrante[]
}

model PlanillaIntegrante {
  id       String @id @default(uuid())
  opcionId String
  opcion   Opcion @relation(fields: [opcionId], references: [id], onDelete: Cascade)
  puesto   String
  nombre   String
}

model Voto {
  id           String   @id @default(uuid())
  procesoId    String
  proceso      Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  folioAnonimo String
  contenido    Json
  canal        String   @default("digital")
  emitidoAt    DateTime @default(now())

  @@unique([procesoId, folioAnonimo])
  @@index([procesoId])
}

model EmisionPadron {
  id           String   @id @default(uuid())
  procesoId    String
  proceso      Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  folioAnonimo String
  canal        String   @default("digital")
  marcadoAt    DateTime @default(now())

  @@unique([procesoId, folioAnonimo])
}

model Incidencia {
  id          String   @id @default(uuid())
  asambleaId  String
  asamblea    Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  tipo        String
  descripcion String
  reportadoAt DateTime @default(now())
}

model Acta {
  id         String   @id @default(uuid())
  procesoId  String   @unique
  proceso    Proceso  @relation(fields: [procesoId], references: [id], onDelete: Cascade)
  pdfPath    String
  hashSha256 String
  resultados Json
  generadaAt DateTime @default(now())
}

// ─── SEGUIMIENTO (TRAZABILIDAD DE PRIORIZACIÓN) ───────────────

model Seguimiento {
  id                 String    @id @default(uuid())
  asambleaId         String
  asamblea           Asamblea  @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  // Opción a la que corresponde esta tarea
  opcionNombre       String    @default("")
  opcionId           String?   // referencia no-FK para conservar si cambia
  // Prioridad según resultado de votación
  prioridad          Int       @default(1)   // 1 = más urgente
  puntos             Int       @default(0)   // puntos obtenidos en votación
  // Datos de gestión
  responsable        String    @default("")
  fechaCompromiso    DateTime?
  presupuestoTotal   Float?    // MXN asignado
  presupuestoEjecutado Float?  // MXN gastado
  estatus            String    @default("pendiente") // pendiente|en_proceso|completado|bloqueado
  actualizadoAt      DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  actualizaciones ActualizacionSeguimiento[]

  @@index([asambleaId, prioridad])
}

// ─── ACTUALIZACIONES DE SEGUIMIENTO ──────────────────────────

model ActualizacionSeguimiento {
  id             String      @id @default(uuid())
  seguimientoId  String
  seguimiento    Seguimiento @relation(fields: [seguimientoId], references: [id], onDelete: Cascade)
  autorId        String?
  autor          Usuario?    @relation(fields: [autorId], references: [id])
  // Contenido de la actualización
  mensaje        String
  imagenPath     String?     // foto de evidencia
  presupuesto    Float?      // monto específico de esta actualización (opcional)
  tipo           String      @default("avance")
  // avance | inicio | completado | incidencia | presupuesto | foto
  createdAt      DateTime    @default(now())

  @@index([seguimientoId, createdAt])
}

// ─── ASAMBLEA DELIBERATIVA ─────────────────────────────────────

model AsistenteAsamblea {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  unidoAt    DateTime @default(now())

  @@unique([asambleaId, usuarioId])
}

model MensajeAsamblea {
  id         String   @id @default(uuid())
  asambleaId String
  asamblea   Asamblea @relation(fields: [asambleaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  contenido  String
  esAnonimo  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([asambleaId, createdAt])
}

// ─── FEED ─────────────────────────────────────────────────────

model Post {
  id                String          @id @default(uuid())
  fraccionamientoId String
  fraccionamiento   Fraccionamiento @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  autorId           String?
  autor             Usuario?        @relation(fields: [autorId], references: [id])
  tipo              String          @default("manual")
  titulo            String          @default("")
  contenido         String
  imagenPath        String?
  asambleaId        String?
  procesoId         String?
  reporteId         String?
  seguimientoId     String?
  createdAt         DateTime        @default(now())

  comentarios Comentario[]
  likes       Like[]

  @@index([fraccionamientoId, createdAt])
}

model Comentario {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  contenido String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Like {
  id        String  @id @default(uuid())
  postId    String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([postId, usuarioId])
}

// ─── REPORTES ─────────────────────────────────────────────────

model Reporte {
  id                  String           @id @default(uuid())
  fraccionamientoId   String
  fraccionamiento     Fraccionamiento  @relation(fields: [fraccionamientoId], references: [id], onDelete: Cascade)
  autorId             String
  autor               Usuario          @relation(fields: [autorId], references: [id])
  categoria           CategoriaReporte
  titulo              String
  descripcion         String
  imagenPath          String?
  ubicacionLat        Float?
  ubicacionLng        Float?
  estatus             EstatusReporte   @default(ABIERTO)
  convertidoEnProceso String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([fraccionamientoId, createdAt])
}
